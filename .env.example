# TalentNG Frontend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration (Required)
# =============================================================================

# Backend API URL - Update this to point to your TalentNG API server
# Development: http://localhost:3000/api/v1
# Production: https://api.talentng.com/api/v1
NEXT_PUBLIC_TALENTNG_API_URL=http://localhost:3000/api/v1

# =============================================================================
# Authentication (Required for Development)
# =============================================================================

# JWT Secret - Used for token signing/verification
# Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-production

# =============================================================================
# Development/Testing Credentials (Optional)
# =============================================================================

# Test account credentials for development
# Remove or leave empty in production
EMAIL=
PASSWORD=

# =============================================================================
# Additional Configuration (Optional)
# =============================================================================

# API URL for server-side requests (if different from NEXT_PUBLIC_TALENTNG_API_URL)
# API_URL=http://localhost:3000/api/v1

# Node environment (automatically set by Next.js)
# NODE_ENV=development

# =============================================================================
# Notes
# =============================================================================

# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Never commit sensitive credentials to version control
# - Use different secrets for development and production
# - Ensure backend API is running before starting the frontend
