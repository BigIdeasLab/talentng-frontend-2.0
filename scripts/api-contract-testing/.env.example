# API Contract Testing Configuration

# API Base URL (required)
API_URL=http://localhost:3000/api/v1

# Authentication Method 1: Token-based (use this OR email/password below)
ACCESS_TOKEN=your_access_token_here

# Authentication Method 2: Email/Password (use this OR token above)
# EMAIL=user@example.com
# PASSWORD=your_password_here

# Note: Provide either ACCESS_TOKEN or both EMAIL and PASSWORD
# The tool will automatically detect which authentication method to use
