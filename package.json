{
  "name": "talentng-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 8080 -H 0.0.0.0",
    "dev:mobile": "node scripts/setup-mobile-env.js && npm run dev",
    "mobile:setup": "node scripts/setup-mobile-env.js",
    "mobile:coordinate": "node scripts/coordinate-mobile-setup.js",
    "mobile:ip": "node scripts/get-local-ip.js",
    "mobile:diagnose": "node scripts/network-diagnostics.js",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:api-contracts": "tsx scripts/api-contract-testing/index.ts",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:headed": "playwright test --headed",
    "test:visual:debug": "playwright test --debug",
    "test:visual:update": "playwright test --update-snapshots",
    "format.fix": "prettier --write .",
    "typecheck": "tsc",
    "pre-deploy": "npm run typecheck && npm run test && npm run build",
    "audit:all": "npm audit && npm run typecheck && npm run test && npm run lint 2>&1 | findstr /c:\"problems\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/query-sync-storage-persister": "^5.90.13",
    "@tanstack/react-query": "^5.84.2",
    "@tanstack/react-query-persist-client": "^5.90.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.22",
    "input-otp": "^1.4.2",
    "jose": "^6.1.0",
    "lucide-react": "^0.539.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.1",
    "react-window": "^2.2.7",
    "react-window-infinite-loader": "^2.0.1",
    "recharts": "^2.12.7",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.4",
    "@playwright/test": "^1.58.2",
    "@swc/core": "^1.13.3",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.2.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.21",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "fast-check": "^4.5.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
